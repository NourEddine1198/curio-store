# ─── Database ────────────────────────────────────────────────
# Get a free Postgres DB from Neon (neon.tech) or Supabase (supabase.com)
DATABASE_URL="postgresql://user:password@host:5432/curio?schema=public"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Ecotrack Shipping Integration ────────────────────────────
ECOTRACK_TOKEN=""             # Your API token from Ecotrack (anderson-ecommerce.ecotrack.dz)

# ─── OrderDZ Integration ─────────────────────────────────────────────
ORDERDZ_API_URL="https://orderdz.com/api/v1"      # Base URL for OrderDZ API
ORDERDZ_API_KEY=""                                 # Bearer token from OrderDZ
ORDERDZ_WEBHOOK_SECRET=""                          # Secret for webhook security

# ─── Coupons ─────────────────────────────────────────────────
# COUPON_INSTAGRAM_EXPIRES=""   # ISO date when coupon expires (e.g. "2026-03-15T22:00:00+01:00")
