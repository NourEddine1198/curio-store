# ─── Database ────────────────────────────────────────────────
# Get a free Postgres DB from Neon (neon.tech) or Supabase (supabase.com)
DATABASE_URL="postgresql://user:password@host:5432/curio?schema=public"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Ecotrack Shipping Integration ────────────────────────────
ECOTRACK_TOKEN=""             # Your API token from Ecotrack (anderson-ecommerce.ecotrack.dz)

# ─── OrderDZ Integration (fill in when they send API details) ────────
# ORDERDZ_API_URL=""          # Their API endpoint (e.g. https://api.orderdz.com/v1/orders)
# ORDERDZ_API_KEY=""          # Your auth key for sending orders to them
# ORDERDZ_WEBHOOK_SECRET=""   # Secret they include when calling our webhook back
